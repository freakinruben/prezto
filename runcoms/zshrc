export PATH="$BUN_INSTALL/bin:$PATH"

# Override Prezto git-module `gpc` (was: git push --set-upstream) → Play Console CLI
alias gpc='playconsole-cli'

# ── Modern CLI productivity ──────────────────────────────────────────────
# Bigger history (prezto defaults to 10000)
export HISTSIZE=200000
export SAVEHIST=200000

# fzf — fuzzy finder + key bindings: Ctrl-R history, Ctrl-T files, Alt-C cd
source <(fzf --zsh)

# eza — modern ls (icons, git status, tree)
alias ls='eza --group-directories-first'
alias ll='eza -lah --git --group-directories-first'
alias la='eza -a --group-directories-first'
alias lt='eza --tree --level=2 --group-directories-first'

# bat — cat with syntax highlight (plain, no pager, so it stays cat-like)
alias cat='bat --plain --paging=never'
export BAT_THEME='ansi'
# fd available as `fd` (faster `find`, different syntax — not aliased over find)

# starship prompt (replaces the prezto 'ruben' theme) — MUST be last
eval "$(starship init zsh)"
