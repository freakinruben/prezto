# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Customize to your needs...

expand-or-complete-with-dots() {      # This bunch of code displays red dots when autocompleting
  echo -n "\e[31m......\e[0m"         # a command with the tab key, "Oh-my-zsh"-style.
  zle expand-or-complete
  zle redisplay
}
zle -N expand-or-complete-with-dots
bindkey "^I" expand-or-complete-with-dots

# zoxide — smart cd (replaces autojump): `z foo` jumps to best match, `zi` interactive
eval "$(zoxide init zsh)"

# color highlighting in man pages
cman() {
  env \
    LESS_TERMCAP_mb=$(printf "\e[1;31m") \
    LESS_TERMCAP_md=$(printf "\e[1;31m") \
    LESS_TERMCAP_me=$(printf "\e[0m") \
    LESS_TERMCAP_se=$(printf "\e[0m") \
    LESS_TERMCAP_so=$(printf "\e[1;44;33m") \
    LESS_TERMCAP_ue=$(printf "\e[0m") \
    LESS_TERMCAP_us=$(printf "\e[1;32m") \
    man "$@"
}

export PATH="/usr/local/opt/curl/bin:$PATH"
export PATH="/usr/local/opt/python/libexec/bin:$PATH"

# copied from https://stackoverflow.com/a/11768843
function change_commits () {
  VAR=$1; OLD=$2; NEW=$3; shift 3;
  git filter-branch \
    -f \
    --env-filter \
    "if [[ \"$`echo $VAR`\" = '$OLD' ]]; then export $VAR='$NEW'; fi" \
    HEAD;
}

function change_git_prj_email () {
  oldEmail="$1"
  newEmail="$2"
  git config user.email "$newEmail"
  change_commits GIT_AUTHOR_EMAIL "$oldEmail" "$newEmail"
  change_commits GIT_COMMITTER_EMAIL "$oldEmail" "$newEmail"
}

# rbenv — lazy: shims on PATH (instant resolution); shell-init hook deferred to first `rbenv` call
export PATH="$HOME/.rbenv/shims:$PATH"
rbenv() { unset -f rbenv; eval "$(command rbenv init -)"; rbenv "$@"; }

alias du="ncdu --color dark -rr -x --exclude .git --exclude node_modules"

# NVM support — default node bin on PATH directly: node/npm/npx + global npm CLIs (cloak, etc.)
# resolve instantly with zero startup cost. nvm itself stays lazy (loads on first `nvm` call,
# e.g. `nvm use`/`nvm install`). Saves ~1.4s vs eager `nvm_auto`.
# Trade-off: .nvmrc no longer auto-switches; run `nvm use` in a project to override the default.
export NVM_DIR="$HOME/.nvm"
if [ -r "$NVM_DIR/alias/default" ]; then
  _nvm_default="$(<$NVM_DIR/alias/default)"
  [ -d "$NVM_DIR/versions/node/$_nvm_default/bin" ] && \
    export PATH="$NVM_DIR/versions/node/$_nvm_default/bin:$PATH"
  unset _nvm_default
fi
nvm() {
  unset -f nvm
  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
  [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
  nvm "$@"
}
# Auto `nvm use` when cd-ing into a dir with .nvmrc (first hit loads nvm via the lazy stub).
autoload -Uz add-zsh-hook
_nvmrc_autoload() { [ -f .nvmrc ] && nvm use >/dev/null 2>&1 }
add-zsh-hook chpwd _nvmrc_autoload

export PATH="/opt/homebrew/opt/openjdk/bin:$PATH"

alias gpn='git push --no-verify'
alias gpcn='git push --set-upstream origin "$(git-branch-current 2> /dev/null)" --no-verify'
export PATH="/opt/homebrew/opt/openjdk@17/bin:$PATH"

# PyENV — lazy: bin + shims on PATH (python/.python-version work instantly via shims);
# shell-init hook (rehash, `pyenv shell`, prompt) deferred to first `pyenv` call.
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
export PATH="$PYENV_ROOT/shims:$PATH"
pyenv() { unset -f pyenv; eval "$(command pyenv init -)"; pyenv "$@"; }

